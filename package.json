{
  "name": "design-duck",
  "version": "1.1.8",
  "description": "Requirements gathering and management tool",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "design-duck": "dist/cli.js",
    "dd": "dist/cli.js"
  },
  "files": [
    "dist/",
    "dist-ui/"
  ],
  "scripts": {
    "build": "npm run build:cli && npm run build:ui",
    "build:cli": "esbuild src/cli.ts --bundle --outfile=dist/cli.js --platform=node --format=esm",
    "build:ui": "vite build",
    "prepare": "npm run build",
    "start": "node dist/cli.js",
    "dev:ui": "vite --open",
    "test": "bun test",
    "release:patch": "npm version patch && git push origin HEAD && git push origin --tags",
    "release:minor": "npm version minor && git push origin HEAD && git push origin --tags",
    "release:major": "npm version major && git push origin HEAD && git push origin --tags"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "requirements",
    "yaml",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "bun-types": "latest",
    "esbuild": "^0.25.0",
    "js-yaml": "^4.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "zustand": "^5.0.10"
  }
}
